# Copy this to .env and fill in your values
# NEVER commit .env to git

# Dhan API (market data) — TOTP-based auto-refresh recommended
# Set up on web.dhan.co → Profile → DhanHQ Trading APIs → Setup TOTP
# (capture the base32 secret shown alongside the QR code)
DHAN_CLIENT_ID=your_dhan_client_id
DHAN_PIN=your_dhan_login_pin            # 4-6 digit PIN used to login
DHAN_TOTP_SECRET=your_base32_totp_secret # Base32 string from QR enrollment
# Optional fallback if TOTP not configured — manually-set 24h token:
DHAN_ACCESS_TOKEN=

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Telegram Notifications
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
